---

import Default from '../layouts/Default.astro';
import Carousel from '../components/Carousel.astro';
import CarouselSlide from '../components/CarouselSlide.astro';
import Spacer from '../components/Spacer.astro';

---

<Default title="Playground">

  <Spacer size="x-lg" />

  <Carousel variant="4" throwDuration={0.5}>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">01</span></CarouselSlide>
    <CarouselSlide src="/images/img2.jpg"><span class="text-5xl">02</span></CarouselSlide>
    <CarouselSlide src="/images/img3.jpg"><span class="text-5xl">03</span></CarouselSlide>
  </Carousel>

  <div class="py-10 text-center">
    <h3 class="pb-5">Pregnancy &amp; New Baby</h3>
    <a href="/typography" class="">Welcome a new bundle of joy with joyful gift bundles.</a>
  </div>

  <div class="products-block">
    <div class="product">
      <div class="product-image"></div>
      <div class="product-meta">
        <div class="stars">
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <span class="rating-value">5.0</span>
        </div>
        <div class="title">Title of Product Here</div>
        <div class="price">$99.99</div>
      </div>
    </div>
  </div>

</Default>
