---

import Default from '../layouts/Default.astro';
import Carousel from '../components/Carousel.astro';
import CarouselSlide from '../components/CarouselSlide.astro';

---

<Default title="Playground">

  <div class="slider-headline">
    <h1 class="">Heading 1</h1>
    <a href="/typography" class="">Typography</a>
  </div>

  <div class="products-block">
    <div class="product">
      <div class="product-image"></div>
      <div class="product-meta">
        <div class="stars">
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <span class="rating-value">5.0</span>
        </div>
        <div class="title">Title of Product Here</div>
        <div class="price">$99.99</div>
      </div>
    </div>
  </div>

  <Carousel variant="3" class="bg-neutral-950" throwDuration={2} data-mode="dark">
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">01</span></CarouselSlide>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">02</span></CarouselSlide>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">03</span></CarouselSlide>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">04</span></CarouselSlide>
  </Carousel>

  <Carousel variant="2" navDuration={0.2} dragSpeed={1.4} throwDuration={1} class="bg-amber-500" data-mode="dark">
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">01</span></CarouselSlide>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">02</span></CarouselSlide>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">03</span></CarouselSlide>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">04</span></CarouselSlide>
  </Carousel>

  <Carousel variant="1" throwDuration={0.5}>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">01</span></CarouselSlide>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">02</span></CarouselSlide>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">03</span></CarouselSlide>
    <CarouselSlide src="/images/img.jpg"><span class="text-5xl">04</span></CarouselSlide>
  </Carousel>

</Default>
