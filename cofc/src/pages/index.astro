---

import Default from '../layouts/Default.astro';

---

<Default title="Playground">

  <style></style>

  <div class="slider">
    <div class="slides">
      <div class="slide"><img src="/public/images/img.jpg"></div>
      <div class="slide"><img src="/public/images/img.jpg"></div>
      <div class="slide"><img src="/public/images/img.jpg"></div>
      <div class="slide"><img src="/public/images/img.jpg"></div>
    </div>
  </div>

  <div class="slider-controls">
    <button class="slider-control"><i class="fa-solid fa-arrow-left"></i></button>
    <button class="slider-control"><i class="fa-solid fa-arrow-right"></i></button>
  </div>

  <div class="slider-headline">
    <h1 class="">Heading 1</h1>
    <a href="/typography" class="">Typography</a>
  </div>

  <div class="products-block">
    <div class="product">
      <div class="product-image"></div>
      <div class="product-meta">
        <div class="stars">
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <i class="fa-solid fa-star"></i>
          <span class="rating-value">5.0</span>
        </div>
        <div class="title">Title of Product Here</div>
        <div class="price">$99.99</div>
      </div>
    </div>
  </div>

  <section class="carousel_wrap">
		<div class="carousel_contain carousel-3">
			<div class="carousel_slides">
				<div class="carousel_slide"><div class="carousel_slide_content">1</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">2</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">3</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">4</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">5</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">6</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">7</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">8</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">9</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">10</div></div>
			</div>
			<div class="carousel_progress">
				<div class="carousel_progress_bar"></div>
			</div>
			<div class="carousel_controls">
				<div class="carousel_progress_dots"></div>
				<div class="carousel_buttons">
					<button class="btn icon-btn prev"><i class="fa-regular fa-arrow-left"></i></button>
					<button class="btn icon-btn next"><i class="fa-regular fa-arrow-right"></i></button>
				</div>
			</div>
		</div>
	</section>
	<section class="carousel_wrap">
		<div class="carousel_contain carousel-2">
			<div class="carousel_slides">
				<div class="carousel_slide"><div class="carousel_slide_content">1</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">2</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">3</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">4</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">5</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">6</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">7</div></div>
			</div>
			<div class="carousel_progress">
				<div class="carousel_progress_bar"></div>
			</div>
			<div class="carousel_controls">
				<div class="carousel_progress_dots"></div>
				<div class="carousel_buttons">
					<button class="btn icon-btn prev"><i class="fa-regular fa-arrow-left"></i></button>
					<button class="btn icon-btn next"><i class="fa-regular fa-arrow-right"></i></button>
				</div>
			</div>
		</div>
	</section>
	<section class="carousel_wrap">
		<div class="carousel_contain carousel-1">
			<div class="carousel_slides">
				<div class="carousel_slide"><div class="carousel_slide_content">1</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">2</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">3</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">4</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">5</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">6</div></div>
				<div class="carousel_slide"><div class="carousel_slide_content">7</div></div>
			</div>
			<div class="carousel_progress">
				<div class="carousel_progress_bar"></div>
			</div>
			<div class="carousel_controls">
				<div class="carousel_progress_dots"></div>
				<div class="carousel_buttons">
					<button class="btn icon-btn prev"><i class="fa-regular fa-arrow-left"></i></button>
					<button class="btn icon-btn next"><i class="fa-regular fa-arrow-right"></i></button>
				</div>
			</div>
		</div>
	</section>
	<!-- Custom Scripts -->
	<script>
		import "../scripts/carousels.js";
	</script>

</Default>
