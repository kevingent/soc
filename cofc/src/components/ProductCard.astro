---

interface Props {
	src: string;
	title: string;
	price: string;
	/** Star rating value displayed next to the stars, e.g. "4.8" */
	rating?: string;
	/** Number of full stars to render (0–5) */
	stars?: number;
	/** Optional link for the product */
	href?: string;
}

const {
	src,
	title,
	price,
	rating = "5.0",
	stars = 5,
	href = "#",
} = Astro.props;

const clampedStars = Math.min(5, Math.max(0, stars));
const resolvedSrc = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/${src.replace(/^\//, '')}`;

---

<div class="product">
	<a class="product-image" href={href}>
		<img src={resolvedSrc} alt={title} loading="lazy" />
	</a>
	<div class="product-meta">
		<div class="stars py-5 text-amber-400">
			{Array.from({ length: clampedStars }).map(() => (
				<i class="fa-solid fa-star"></i>
			))}
			{Array.from({ length: 5 - clampedStars }).map(() => (
				<i class="fa-regular fa-star"></i>
			))}
			<span class="rating-value text-sm pl-1 text-zinc-700">{rating}</span>
		</div>
		<div class="title text-base pb-4">{title}</div>
		<div class="price text-xl">{price}</div>
	</div>
</div>

<style>
	.product {
		display: flex;
		flex-direction: column;
	}

	.product-image {
		display: block;
		aspect-ratio: 1 / 1;
		max-width: 588px;
		overflow: hidden;

		img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
			transition: transform 0.4s ease;
		}

		&:hover img {
			transform: scale(1.03);
		}
	}

	.product-meta {
		.stars {
			display: flex;
			align-items: center;
			justify-content: flex-start;

			i {
				font-size: 13px;
			}
		}
	}
</style>
